<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_styd_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.styd.bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app
                    string="Speak To Your Database"
                     name="styd_odoo_bridge"
                     logo="/styd_odoo_bridge/static/description/icon.png">
                    <block title="STYD Bridge" name="styd_bridge_block">
                        <setting
                            string="Enable STYD Bridge"
                            help="Enable the STYD security bridge endpoints for this Odoo database."
                            id="styd_bridge_enabled_setting"
                        >
                            <field name="styd_bridge_enabled"/>
                        </setting>

                        <setting
                            string="STYD Bridge Token"
                            help="Bearer token used by Speak to your Database to authenticate to the Odoo bridge."
                            id="styd_bridge_token_setting"
                        >
                            <field
                                name="styd_bridge_token"
                                password="True"
                                placeholder="Paste the STYD bridge token"
                            />
                        </setting>

                        <setting
                            string="STYD Connector Owner"
                            help="Odoo user whose trusted security scope will be used as the initial connector-owner snapshot."
                            id="styd_bridge_connector_owner_setting"
                        >
                            <field
                                name="styd_bridge_connector_owner_user_id"
                                options="{'no_create': True}"
                            />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>