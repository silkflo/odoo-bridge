<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_styd_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.styd.bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block"
                     data-string="Speak To Your Database"
                     string="Speak To Your Database"
                     data-key="styd_odoo_bridge">

                    <h2>Speak To Your Database Bridge</h2>

                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="styd_bridge_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="styd_bridge_enabled"/>
                                <div class="text-muted">
                                    Enable the Speak To Your Database security bridge endpoints for this Odoo database.
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="styd_bridge_token"/>
                                <div class="text-muted">
                                    Bearer token used by Speak To Your Database to authenticate to the Odoo bridge.
                                </div>
                                <field
                                    name="styd_bridge_token"
                                    password="True"
                                    placeholder="Paste the Speak To Your Database bridge token"
                                />
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="styd_bridge_connector_owner_user_id"/>
                                <div class="text-muted">
                                    Odoo user whose trusted security scope will be used as the initial connector-owner snapshot.
                                </div>
                                <field
                                    name="styd_bridge_connector_owner_user_id"
                                    options="{'no_create': True}"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_styd_bridge_settings" model="ir.actions.act_window">
        <field name="name">Speak To Your Database Bridge</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'styd_odoo_bridge'}</field>
    </record>

    <menuitem
        id="menu_styd_bridge_settings"
        name="Speak To Your Database Bridge"
        parent="base.menu_administration"
        action="action_styd_bridge_settings"
        sequence="5"
    />
</odoo>